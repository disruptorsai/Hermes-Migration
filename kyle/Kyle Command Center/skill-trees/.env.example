# Port to run the server on (default: 5050)
PORT=5050

# Root directory to scan for agents and skills
# Default points to the included example workspace.
# Change this to your own workspace root when ready.
SKILL_TREE_ROOT=./example-workspace

# Platform hint: auto, claude-code, openclaw, antigravity
# "auto" tries all patterns. Set explicitly if auto-detect gets it wrong.
PLATFORM=auto
